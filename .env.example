# Cloudinary (for media uploads via client)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here

# Firebase example (these are usually already in your Firebase config file or can be placed here if you prefer)
